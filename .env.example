# Copia este archivo a .env.local y completa los valores
DATABASE_URL="postgresql://..."
JWT_SECRET="min-32-chars-secret-change-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ─── DTE Ministerio de Hacienda El Salvador ────────────────────────────────
# Modo: offline (sin conexión) | test (ambiente pruebas MH) | production
DTE_MODE=offline

# Datos del emisor (Fundación ASISTEDCOS)
DTE_NIT=
DTE_NRC=
DTE_NOMBRE="Fundación ASISTEDCOS"
DTE_NOMBRE_COMERCIAL=
DTE_ACTIVIDAD=84120
DTE_DESC_ACTIVIDAD="Actividades de otras organizaciones y asociaciones n.c.p."
DTE_TIPO_ESTABLECIMIENTO=01
DTE_COD_ESTABLECIMIENTO=0001
DTE_COD_PTO_VENTA=0001
DTE_DIRECCION_DEPARTAMENTO=06
DTE_DIRECCION_MUNICIPIO=23
DTE_DIRECCION_COMPLEMENTO=
DTE_TELEFONO=
DTE_CORREO=

# Credenciales API MH (necesarias para DTE_MODE=test o production)
DTE_MH_USER=
DTE_MH_PASSWORD=

# Servicio de firma digital (opcional — necesario para envío real al MH)
# URL del servicio de firma proporcionado por MH o proveedor autorizado
DTE_SIGNING_URL=
DTE_SIGNING_PASSWORD=
